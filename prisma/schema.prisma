generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CURATOR
  USER
}

enum ProductType {
  COURSE
  MARATHON
}

enum UnlockRule {
  IMMEDIATELY
  AFTER_HOMEWORK_APPROVAL
  SPECIFIC_DATE
}

enum HomeworkStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum LiveRoomStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum LiveRoomParticipantRole {
  HOST
  SPEAKER
  VIEWER
}

enum LiveRecordingStatus {
  IDLE
  RECORDING
  PROCESSING
  READY
  FAILED
}

enum LiveRecordingProfile {
  AUDIO
  LOW
  HIGH
}

enum MarathonEventType {
  INFO
  TRAINING
  NUTRITION
  PROCEDURE
  BONUS
  LIVE
  RESULT
}

enum MarathonTrack {
  ALL
  HOME
  GYM
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// Возможности продукта/тарифа — каждый ключ должен иметь явные гейты в коде.
enum ProductCriterion {
  NUTRITION_CONTENT
  ONLINE_TRAINING
  TASKS
  COMMUNITY_CHAT
  HOMEWORK_REVIEW
  CURATOR_FEEDBACK
  MARATHON_LIVE
}

enum PaymentKind {
  INITIAL
  UPGRADE
}

enum TariffUpgradeStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  APPLIED
  CANCELLED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  lastSignInAt DateTime?
  lastActiveAt DateTime?
  /// Вес в кг (личные данные профиля студента)
  weight       Float?
  /// Рост в см
  height       Float?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollments     Enrollment[]
  submissions     HomeworkSubmission[]
  chatMessages    ChatMessage[]
  liveRoomParticipants LiveRoomParticipant[]
  liveChatMessages     LiveChatMessage[]
  curatedProducts ProductCurator[]
  accounts        Account[]
  sessions        Session[]
  payments        Payment[]
  feedbackMessages CuratorFeedbackMessage[]
  enrollmentTariffAuthorship EnrollmentTariffHistory[] @relation("EnrollmentTariffHistoryAuthor")
  progressPhotos  UserProgressPhoto[]
  measurements    UserMeasurement[]

  @@map("users")
}

enum ProgressPhotoType {
  BEFORE
  AFTER
}

/// Фото прогресса студента (до/после), до 4 в каждой категории
model UserProgressPhoto {
  id        String            @id @default(uuid())
  userId    String
  type      ProgressPhotoType
  url       String
  position  Int               @default(0)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, position])
  @@map("user_progress_photos")
}

/// Замеры студента: все значения в см
model UserMeasurement {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  shoulders   Float?
  aboveChest  Float?
  belowChest  Float?
  waist       Float?
  abdomen     Float?
  hips        Float?
  thighRight  Float?
  thighLeft   Float?
  calfRight   Float?
  calfLeft    Float?
  armRight    Float?
  armLeft     Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("user_measurements")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id           String      @id @default(uuid())
  type         ProductType
  title        String
  slug         String      @unique
  description  String?     @db.Text
  coverUrl     String?
  /// Ссылка на Яндекс.Форму (или другую форму оплаты); в URL добавляется ?paymentRef=…
  paymentFormUrl String?   @db.Text
  price        Decimal?    @db.Decimal(10, 2)
  currency     String      @default("RUB")
  /// Какие критерии вообще доступны для этого продукта (тариф может включить только подмножество).
  enabledCriteria ProductCriterion[] @default([])
  published    Boolean     @default(false)
  startDate    DateTime? // for MARATHON type
  durationDays Int? // for MARATHON type, used for event scheduling
  /// Блоки лендинга продукта: [{id, type, ...fields}]
  landingBlocks Json?
  /// Правила курса/марафона (markdown). Если задано — отображается в сайдбаре студента.
  rules        String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  lessons            Lesson[]
  enrollments        Enrollment[]
  marathonEvents     MarathonEvent[]
  curatorAssignments ProductCurator[]
  payments           Payment[]
  tariffs            ProductTariff[]

  @@index([slug])
  @@index([type])
  @@map("products")
}

model ProductTariff {
  id          String             @id @default(uuid())
  productId   String
  name        String
  price       Decimal            @db.Decimal(10, 2)
  currency    String             @default("RUB")
  sortOrder   Int                @default(0)
  published   Boolean            @default(true)
  criteria    ProductCriterion[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  enrollments          Enrollment[]
  payments             Payment[]            @relation("PaymentTariff")
  upgradesFrom         TariffUpgrade[]      @relation("TariffUpgradeFrom")
  upgradesTo           TariffUpgrade[]      @relation("TariffUpgradeTo")
  enrollmentHistoryFrom EnrollmentTariffHistory[] @relation("EnrollmentHistoryFrom")
  enrollmentHistoryTo   EnrollmentTariffHistory[] @relation("EnrollmentHistoryTo")

  @@index([productId, sortOrder])
  @@index([productId, published])
  @@map("product_tariffs")
}

model Payment {
  id                  String        @id @default(uuid())
  reference           String        @unique
  /// Идентификатор операции из HTTP-уведомления ЮMoney (идемпотентность повторных доставок).
  yoomoneyOperationId String?       @unique
  userId              String
  productId           String
  kind                PaymentKind   @default(INITIAL)
  /// Тариф первичной оплаты (для kind = INITIAL).
  tariffId            String?
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("RUB")
  status              PaymentStatus @default(PENDING)
  rawPayload          Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tariff  ProductTariff? @relation("PaymentTariff", fields: [tariffId], references: [id], onDelete: SetNull)

  tariffUpgrade TariffUpgrade?

  @@index([userId, productId])
  @@index([productId, status])
  @@index([tariffId])
  @@map("payments")
}

model TariffUpgrade {
  id                      String              @id @default(uuid())
  enrollmentId            String
  fromTariffId            String
  toTariffId              String
  status                  TariffUpgradeStatus @default(DRAFT)
  quotedFromPrice         Decimal             @db.Decimal(10, 2)
  quotedToPrice           Decimal             @db.Decimal(10, 2)
  quotedDelta             Decimal             @db.Decimal(10, 2)
  currency                String              @default("RUB")
  paymentId               String?             @unique
  appliedCriteriaSnapshot Json?
  expiresAt               DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  enrollment Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  fromTariff ProductTariff @relation("TariffUpgradeFrom", fields: [fromTariffId], references: [id], onDelete: Restrict)
  toTariff   ProductTariff @relation("TariffUpgradeTo", fields: [toTariffId], references: [id], onDelete: Restrict)
  payment    Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([enrollmentId, status])
  @@index([toTariffId])
  @@map("tariff_upgrades")
}

model EnrollmentTariffHistory {
  id              String   @id @default(uuid())
  enrollmentId    String
  fromTariffId    String?
  toTariffId      String
  reason          String   @default("payment")
  changedByUserId String?
  createdAt       DateTime @default(now())

  enrollment Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  fromTariff ProductTariff? @relation("EnrollmentHistoryFrom", fields: [fromTariffId], references: [id], onDelete: SetNull)
  toTariff   ProductTariff  @relation("EnrollmentHistoryTo", fields: [toTariffId], references: [id], onDelete: Restrict)
  changedBy  User?          @relation("EnrollmentTariffHistoryAuthor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([enrollmentId, createdAt])
  @@map("enrollment_tariff_history")
}

model CuratorFeedbackMessage {
  id           String    @id @default(uuid())
  enrollmentId String
  userId       String
  content      String    @db.Text
  /// Массив вложений: [{ url, type: "image"|"video"|"file", name, size }]
  attachments  Json?
  createdAt    DateTime  @default(now())
  /// null = не прочитано получателем. Для студенческих сообщений — когда куратор/админ открыл тред.
  readAt       DateTime?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, createdAt])
  @@map("curator_feedback_messages")
}

model Lesson {
  id                String     @id @default(uuid())
  productId         String
  title             String
  slug              String
  order             Int
  content           String?    @db.Text // legacy: Markdown/HTML
  videoUrl          String? // legacy: single video
  blocks            Json? // [{id, type: "text"|"video"|"image", content}]
  homeworkEnabled   Boolean    @default(false)
  homeworkQuestions Json? // ["question1", "question2", ...]
  unlockRule        UnlockRule @default(IMMEDIATELY)
  unlockDate        DateTime?
  unlockDay         Int?
  published         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  attachments           LessonAttachment[]
  marathonEventLessons  MarathonEventLesson[]
  submissions           HomeworkSubmission[]

  @@unique([productId, slug])
  @@index([productId])
  @@index([productId, order])
  @@map("lessons")
}

model LessonAttachment {
  id        String   @id @default(uuid())
  lessonId  String
  name      String
  url       String
  type      String // "image", "video", "document", "link"
  size      Int? // bytes
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_attachments")
}

model Enrollment {
  id        String    @id @default(uuid())
  userId    String
  productId String
  tariffId  String
  expiresAt DateTime?
  progress  Float     @default(0) // 0.0 - 1.0
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  tariff     ProductTariff           @relation(fields: [tariffId], references: [id], onDelete: Restrict)
  procedures UserMarathonProcedure[]
  eventCompletions MarathonEventCompletion[]
  tariffUpgrades TariffUpgrade[]
  tariffHistory  EnrollmentTariffHistory[]
  feedbackMessages CuratorFeedbackMessage[]

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([tariffId])
  @@map("enrollments")
}

model MarathonEvent {
  id          String            @id @default(uuid())
  productId   String
  title       String
  description String?           @db.Text
  type        MarathonEventType
  track       MarathonTrack     @default(ALL)
  dayOffset   Int
  /// Дата/время старта (используем для LIVE; для остальных типов может быть null)
  scheduledAt DateTime?
  weekNumber  Int?
  position    Int               @default(0)
  blocks      Json?
  published   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  product      Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  eventLessons MarathonEventLesson[]
  completions  MarathonEventCompletion[]
  liveRooms    LiveRoom[]

  @@index([productId, dayOffset, position])
  @@index([productId, type])
  @@index([productId, scheduledAt])
  @@map("marathon_events")
}

model LiveRoom {
  id             String                 @id @default(uuid())
  marathonEventId String                @unique
  status         LiveRoomStatus         @default(SCHEDULED)
  title          String?
  /// Максимум спикеров в режиме вебинара
  maxSpeakers    Int                    @default(6)
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  marathonEvent  MarathonEvent          @relation(fields: [marathonEventId], references: [id], onDelete: Cascade)
  participants   LiveRoomParticipant[]
  recordings     LiveRoomRecording[]
  chatMessages   LiveChatMessage[]

  @@index([marathonEventId])
  @@index([status])
  @@map("live_rooms")
}

model LiveRoomParticipant {
  id        String                   @id @default(uuid())
  roomId    String
  userId    String
  role      LiveRoomParticipantRole  @default(VIEWER)
  /// Запрос “стать спикером” (для вебинара)
  speakerRequestedAt DateTime?
  speakerApprovedAt  DateTime?
  joinedAt  DateTime                 @default(now())
  leftAt    DateTime?

  room      LiveRoom                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([role])
  @@map("live_room_participants")
}

model LiveRoomRecording {
  id        String               @id @default(uuid())
  roomId    String
  status    LiveRecordingStatus  @default(IDLE)
  profile   LiveRecordingProfile
  startedAt DateTime?
  endedAt   DateTime?
  /// HLS manifest (m3u8) в S3
  manifestUrl String?
  durationSec Int?
  sizeBytes   BigInt?
  error       String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  room      LiveRoom             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([status])
  @@map("live_room_recordings")
}

model LiveChatMessage {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  content   String   @db.Text
  deletedAt DateTime?
  createdAt DateTime @default(now())

  room LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([userId])
  @@map("live_chat_messages")
}

/// Прикреплённые к событию уроки (порядок — поле position).
model MarathonEventLesson {
  id              String   @id @default(uuid())
  marathonEventId String
  lessonId        String
  position        Int      @default(0)
  createdAt       DateTime @default(now())

  marathonEvent MarathonEvent @relation(fields: [marathonEventId], references: [id], onDelete: Cascade)
  lesson        Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([marathonEventId, lessonId])
  @@index([marathonEventId])
  @@index([lessonId])
  @@map("marathon_event_lessons")
}

model MarathonEventCompletion {
  id           String   @id @default(uuid())
  enrollmentId String
  eventId      String
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollment Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  event      MarathonEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, eventId])
  @@index([enrollmentId])
  @@index([eventId])
  @@map("marathon_event_completions")
}

model ProcedureType {
  id        String   @id @default(uuid())
  title     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items UserMarathonProcedure[]

  @@map("procedure_types")
}

model UserMarathonProcedure {
  id              String    @id @default(uuid())
  enrollmentId    String
  procedureTypeId String
  scheduledAt     DateTime?
  completedAt     DateTime?
  notes           String?   @db.Text
  position        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  enrollment    Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  procedureType ProcedureType @relation(fields: [procedureTypeId], references: [id], onDelete: Restrict)

  @@index([enrollmentId, position])
  @@index([procedureTypeId])
  @@map("user_marathon_procedures")
}

model HomeworkSubmission {
  id        String         @id @default(uuid())
  lessonId  String
  userId    String
  content   String?        @db.Text
  fileUrl   String?
  fileUrls  String[]       @default([])
  status    HomeworkStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  lesson   Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([lessonId])
  @@index([userId])
  @@index([status])
  @@map("homework_submissions")
}

model ChatMessage {
  id           String   @id @default(uuid())
  submissionId String
  userId       String
  content      String   @db.Text
  fileUrl      String?
  fileUrls     String[] @default([])
  replyToId    String?
  createdAt    DateTime @default(now())

  submission HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo    ChatMessage?       @relation("ChatReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    ChatMessage[]      @relation("ChatReplies")

  @@index([submissionId])
  @@index([replyToId])
  @@map("chat_messages")
}

model ProductCurator {
  id        String   @id @default(uuid())
  productId String
  curatorId String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  curator User    @relation(fields: [curatorId], references: [id], onDelete: Cascade)

  @@unique([productId, curatorId])
  @@index([curatorId])
  @@index([productId])
  @@map("product_curators")
}
