[Unit]
Description=LMS Platform Live Server (mediasoup SFU) — thebesteducation.ru
After=network.target

[Service]
Type=simple
User=appuser
Group=appuser
WorkingDirectory=/var/www/platform
Environment=NODE_ENV=production
EnvironmentFile=-/var/www/platform/.env
ExecStart=/usr/bin/env bash -lc 'cd /var/www/platform && /usr/bin/pnpm -s live:server'
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target

