# Скопируй в /var/www/platform/.env на сервере (deploy.sh не перезаписывает .env).
# Значения NEXT_PUBLIC_* должны быть заданы ДО pnpm build на сервере.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

AUTH_SECRET=""
AUTH_URL="https://thebesteducation.ru"

S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="ru-central1"
S3_ENDPOINT="https://storage.yandexcloud.net"

NEXT_PUBLIC_S3_BUCKET=""
NEXT_PUBLIC_S3_ENDPOINT="https://storage.yandexcloud.net"

# Email уведомления (SMTP — например, Yandex Mail или любой другой провайдер)
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@thebesteducation.ru"

# Telegram Bot уведомления для куратора/админа (MAX или любой бот)
# Создай бота через @BotFather, получи токен и chat_id (группы или личного чата)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
